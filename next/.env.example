# Local Supabase connection settings for the Next.js app.
#
# The keys below are the DEFAULT, PUBLIC, local-only Supabase demo keys. They are
# the same on every local Supabase install, are NOT secrets, and are safe to commit.
# Never reuse them for a hosted/production project.
#
# post-create.sh copies this file to .env.local automatically. If `supabase start`
# ever prints different keys (e.g. a newer CLI), paste those into .env.local.

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Server-only (no NEXT_PUBLIC_ prefix). Bypasses Row Level Security — never expose
# this to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
